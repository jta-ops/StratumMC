diff --git a/mc/stratum/audit/AuditLog.java b/mc/stratum/audit/AuditLog.java
new file mode 100644
index 0000000000000000000000000000000000000000..0d354c9c217d4e24a47475dfa44c6fbd953e3841
--- /dev/null
+++ b/mc/stratum/audit/AuditLog.java
@@ -0,0 +1,144 @@
+package mc.stratum.audit;
+
+import java.io.BufferedWriter;
+import java.io.File;
+import java.io.FileOutputStream;
+import java.io.IOException;
+import java.io.OutputStreamWriter;
+import java.nio.charset.StandardCharsets;
+import java.time.Instant;
+import java.time.ZoneOffset;
+import java.time.format.DateTimeFormatter;
+import java.util.concurrent.locks.ReentrantLock;
+import java.util.logging.Logger;
+
+/**
+ * Thread-safe audit log for significant Stratum server events.
+ *
+ * <p>Events are written to {@code logs/stratum-audit.log} in append mode.
+ * Each line has the format: {@code [ISO-8601] [AUDIT] <event>}
+ *
+ * <p>Usage:
+ * <pre>{@code
+ * AuditLog.getInstance().log("ADDON_ENABLED id=my-addon");
+ * }</pre>
+ */
+public final class AuditLog {
+
+    private static final Logger LOGGER = Logger.getLogger("AuditLog");
+    private static final DateTimeFormatter ISO = DateTimeFormatter.ISO_INSTANT;
+
+    private static final AuditLog INSTANCE = new AuditLog();
+
+    private final ReentrantLock lock = new ReentrantLock();
+    private BufferedWriter writer;
+    private boolean initialised = false;
+
+    private AuditLog() {}
+
+    /** Returns the singleton {@link AuditLog}. */
+    public static AuditLog getInstance() {
+        return INSTANCE;
+    }
+
+    // ── Public API ─────────────────────────────────────────────────────────────
+
+    /**
+     * Writes an audit event. Initialises the log file lazily on first call.
+     *
+     * @param event a short, machine-readable description of the event,
+     *              e.g. {@code "TWEAK_LOADED jar=foo.jar"}
+     */
+    public void log(final String event) {
+        final String line = "[" + ISO.format(Instant.now().atOffset(ZoneOffset.UTC)) + "] [AUDIT] " + event;
+
+        lock.lock();
+        try {
+            ensureOpen();
+            if (writer == null) {
+                LOGGER.warning("[Stratum] AuditLog not open — printing to stderr: " + line);
+                System.err.println(line);
+                return;
+            }
+            writer.write(line);
+            writer.newLine();
+            writer.flush();
+        } catch (IOException ex) {
+            LOGGER.warning("[Stratum] Could not write to audit log: " + ex.getMessage());
+        } finally {
+            lock.unlock();
+        }
+    }
+
+    /**
+     * Explicitly initialises the audit log at the given file path.
+     * Called by {@link mc.stratum.StratumServer} during bootstrap.
+     *
+     * @param logFile target file (created including parent directories if absent)
+     */
+    public void init(final File logFile) {
+        lock.lock();
+        try {
+            closeQuietly();
+            logFile.getParentFile().mkdirs();
+            writer = new BufferedWriter(
+                    new OutputStreamWriter(
+                            new FileOutputStream(logFile, /* append= */ true),
+                            StandardCharsets.UTF_8
+                    )
+            );
+            initialised = true;
+            log("AUDIT_LOG_OPENED path=" + logFile.getAbsolutePath());
+        } catch (IOException ex) {
+            LOGGER.severe("[Stratum] Could not open audit log at " + logFile + ": " + ex.getMessage());
+        } finally {
+            lock.unlock();
+        }
+    }
+
+    /** Flushes and closes the log file. Called on server shutdown. */
+    public void close() {
+        lock.lock();
+        try {
+            if (writer != null) {
+                log("AUDIT_LOG_CLOSED");
+                closeQuietly();
+            }
+        } finally {
+            lock.unlock();
+        }
+    }
+
+    // ── Private helpers ────────────────────────────────────────────────────────
+
+    /**
+     * Lazy-init fallback: if {@link #init(File)} was never called, opens the default
+     * log path automatically.
+     */
+    private void ensureOpen() {
+        if (!initialised) {
+            // Attempt default path without holding the lock recursively
+            final File def = new File("logs/stratum-audit.log");
+            def.getParentFile().mkdirs();
+            try {
+                writer = new BufferedWriter(
+                        new OutputStreamWriter(
+                                new FileOutputStream(def, true),
+                                StandardCharsets.UTF_8
+                        )
+                );
+                initialised = true;
+            } catch (IOException ex) {
+                LOGGER.warning("[Stratum] Could not open default audit log: " + ex.getMessage());
+            }
+        }
+    }
+
+    private void closeQuietly() {
+        if (writer != null) {
+            try { writer.close(); } catch (IOException ignored) {}
+            writer = null;
+        }
+        initialised = false;
+    }
+}

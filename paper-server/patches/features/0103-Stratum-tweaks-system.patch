From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Stratum MC <dev@stratum.mc>
Date: Fri, 30 May 2026 00:00:00 +0000
Subject: [PATCH] Stratum tweaks system

Signed, verified, always-on code modules pulled from the Stratum API.
Tweaks are patch-like: never individually disabled, folded into core on
a major version bump.

diff --git a/mc/stratum/tweaks/TweakEntry.java b/mc/stratum/tweaks/TweakEntry.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffffffffffffffffffffffffffffffffffffffff
--- /dev/null
+++ b/mc/stratum/tweaks/TweakEntry.java
@@ -0,0 +1,10 @@
+package mc.stratum.tweaks;
+
+/** Metadata for a single tweak as returned by the Stratum API manifest. */
+public record TweakEntry(
+        String id,
+        String name,
+        String stratumVersion,   // e.g. "Stratum1.3"
+        String downloadUrl,
+        String signature         // base64-encoded Ed25519 detached signature
+) {}
diff --git a/mc/stratum/tweaks/TweakSignatureVerifier.java b/mc/stratum/tweaks/TweakSignatureVerifier.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffffffffffffffffffffffffffffffffffffffff
--- /dev/null
+++ b/mc/stratum/tweaks/TweakSignatureVerifier.java
@@ -0,0 +1,35 @@
+package mc.stratum.tweaks;
+
+import java.io.File;
+import java.nio.file.Files;
+import java.security.PublicKey;
+import java.security.Signature;
+import java.util.Base64;
+
+public final class TweakSignatureVerifier {
+
+    private TweakSignatureVerifier() {}
+
+    /**
+     * Verifies an Ed25519 signature for a JAR file.
+     *
+     * @param jarFile   the JAR to verify
+     * @param sigFile   detached .sig file containing the base64 Ed25519 signature
+     * @param publicKey the bundled Stratum public key
+     * @return true if signature is valid
+     */
+    public static boolean verify(File jarFile, File sigFile, PublicKey publicKey) {
+        try {
+            byte[] jarBytes = Files.readAllBytes(jarFile.toPath());
+            String sigB64 = Files.readString(sigFile.toPath()).trim();
+            byte[] sigBytes = Base64.getDecoder().decode(sigB64);
+
+            Signature sig = Signature.getInstance("Ed25519");
+            sig.initVerify(publicKey);
+            sig.update(jarBytes);
+            return sig.verify(sigBytes);
+        } catch (Exception e) {
+            return false;
+        }
+    }
+}
diff --git a/mc/stratum/tweaks/TweakLoader.java b/mc/stratum/tweaks/TweakLoader.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffffffffffffffffffffffffffffffffffffffff
--- /dev/null
+++ b/mc/stratum/tweaks/TweakLoader.java
@@ -0,0 +1,95 @@
+package mc.stratum.tweaks;
+
+import mc.stratum.audit.AuditLog;
+import org.bukkit.plugin.java.JavaPlugin;
+
+import java.io.File;
+import java.net.URL;
+import java.net.URLClassLoader;
+import java.security.PublicKey;
+import java.util.ArrayList;
+import java.util.Collections;
+import java.util.List;
+import java.util.logging.Logger;
+
+public final class TweakLoader {
+
+    private static TweakLoader INSTANCE;
+    private static final Logger LOG = Logger.getLogger("Stratum/Tweaks");
+
+    private final List<TweakEntry> loaded = new ArrayList<>();
+    private final List<String> rejected = new ArrayList<>();
+
+    private TweakLoader() {}
+
+    public static TweakLoader getInstance() {
+        if (INSTANCE == null) INSTANCE = new TweakLoader();
+        return INSTANCE;
+    }
+
+    /**
+     * Scans tweaksDir for *.jar files, verifies each against its *.sig counterpart,
+     * and loads verified tweaks with an isolated ClassLoader.
+     */
+    public void loadAll(File tweaksDir, PublicKey verificationKey) {
+        if (!tweaksDir.exists()) tweaksDir.mkdirs();
+        File[] jars = tweaksDir.listFiles((d, n) -> n.endsWith(".jar"));
+        if (jars == null || jars.length == 0) {
+            LOG.info("No tweaks found in " + tweaksDir.getPath());
+            return;
+        }
+
+        for (File jar : jars) {
+            File sigFile = new File(jar.getParentFile(), jar.getName().replace(".jar", ".sig"));
+            if (!sigFile.exists()) {
+                String msg = "REJECTED tweak " + jar.getName() + ": missing signature file";
+                LOG.warning(msg);
+                AuditLog.getInstance().log("TWEAK_REJECTED jar=" + jar.getName() + " reason=missing_sig");
+                rejected.add(jar.getName());
+                continue;
+            }
+            if (!TweakSignatureVerifier.verify(jar, sigFile, verificationKey)) {
+                String msg = "REJECTED tweak " + jar.getName() + ": signature verification failed";
+                LOG.severe(msg);
+                AuditLog.getInstance().log("TWEAK_REJECTED jar=" + jar.getName() + " reason=bad_sig");
+                rejected.add(jar.getName());
+                continue;
+            }
+            try {
+                URLClassLoader cl = new URLClassLoader(new URL[]{jar.toURI().toURL()},
+                        TweakLoader.class.getClassLoader());
+                // Read tweak metadata from META-INF/tweak.properties
+                java.util.Properties props = new java.util.Properties();
+                java.io.InputStream is = cl.getResourceAsStream("META-INF/tweak.properties");
+                if (is != null) props.load(is);
+                String id      = props.getProperty("id",      jar.getName());
+                String name    = props.getProperty("name",    jar.getName());
+                String version = props.getProperty("version", "unknown");
+                TweakEntry entry = new TweakEntry(id, name, version, "", "");
+                loaded.add(entry);
+                LOG.info("Loaded tweak " + version + ": " + name);
+                AuditLog.getInstance().log("TWEAK_LOADED id=" + id + " version=" + version);
+            } catch (Exception e) {
+                LOG.severe("Failed to load tweak " + jar.getName() + ": " + e.getMessage());
+                rejected.add(jar.getName());
+            }
+        }
+    }
+
+    public List<String> getLoadedTweakNames() {
+        List<String> names = new ArrayList<>();
+        for (TweakEntry e : loaded) names.add(e.stratumVersion() + ": " + e.name());
+        return Collections.unmodifiableList(names);
+    }
+
+    public List<TweakEntry> getLoadedTweaks() {
+        return Collections.unmodifiableList(loaded);
+    }
+
+    public List<String> getRejected() {
+        return Collections.unmodifiableList(rejected);
+    }
+
+    public int loadedCount()  { return loaded.size(); }
+    public int rejectedCount(){ return rejected.size(); }
+}

From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Stratum MC <dev@stratum.mc>
Date: Fri, 30 May 2026 00:00:00 +0000
Subject: [PATCH] Stratum Prometheus metrics endpoint

Serves /metrics in Prometheus text format on a configurable port.
Toggled via stratum.yml metrics.enabled.

diff --git a/mc/stratum/metrics/StratumMetricsServer.java b/mc/stratum/metrics/StratumMetricsServer.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffffffffffffffffffffffffffffffffffffffff
--- /dev/null
+++ b/mc/stratum/metrics/StratumMetricsServer.java
@@ -0,0 +1,79 @@
+package mc.stratum.metrics;
+
+import com.sun.net.httpserver.HttpServer;
+import mc.stratum.StratumConfig;
+import org.bukkit.Bukkit;
+
+import java.io.IOException;
+import java.io.OutputStream;
+import java.net.InetSocketAddress;
+import java.util.logging.Logger;
+
+public final class StratumMetricsServer {
+
+    private static StratumMetricsServer INSTANCE;
+    private static final Logger LOG = Logger.getLogger("Stratum/Metrics");
+
+    private HttpServer server;
+
+    private StratumMetricsServer() {}
+
+    public static StratumMetricsServer getInstance() {
+        if (INSTANCE == null) INSTANCE = new StratumMetricsServer();
+        return INSTANCE;
+    }
+
+    public void start() {
+        if (!StratumConfig.metricsEnabled) return;
+        try {
+            server = HttpServer.create(new InetSocketAddress(StratumConfig.metricsPort), 0);
+            server.createContext("/metrics", exchange -> {
+                String body = buildMetrics();
+                byte[] bytes = body.getBytes();
+                exchange.getResponseHeaders().set("Content-Type", "text/plain; version=0.0.4; charset=utf-8");
+                exchange.sendResponseHeaders(200, bytes.length);
+                try (OutputStream os = exchange.getResponseBody()) { os.write(bytes); }
+            });
+            server.setExecutor(null);
+            server.start();
+            LOG.info("Metrics endpoint started on :" + StratumConfig.metricsPort + "/metrics");
+        } catch (IOException e) {
+            LOG.severe("Failed to start metrics server: " + e.getMessage());
+        }
+    }
+
+    public void stop() {
+        if (server != null) { server.stop(0); server = null; }
+    }
+
+    private static String buildMetrics() {
+        StringBuilder sb = new StringBuilder();
+        Runtime rt = Runtime.getRuntime();
+        long usedBytes = rt.totalMemory() - rt.freeMemory();
+        long maxBytes  = rt.maxMemory();
+        double[] tps   = Bukkit.getServer().getTPS();
+        double mspt    = Bukkit.getServer().getAverageTickTime();
+        int players    = Bukkit.getOnlinePlayers().size();
+        int maxPlayers = Bukkit.getMaxPlayers();
+        int chunks     = Bukkit.getWorlds().stream().mapToInt(w -> w.getLoadedChunks().length).sum();
+
+        gauge(sb, "stratum_tps", "label=\"1m\"",  tps.length > 0 ? tps[0] : 0);
+        gauge(sb, "stratum_tps", "label=\"5m\"",  tps.length > 1 ? tps[1] : 0);
+        gauge(sb, "stratum_tps", "label=\"15m\"", tps.length > 2 ? tps[2] : 0);
+        gauge(sb, "stratum_mspt", null, mspt);
+        gauge(sb, "stratum_players_online", null, players);
+        gauge(sb, "stratum_players_max",    null, maxPlayers);
+        gauge(sb, "stratum_chunks_loaded",  null, chunks);
+        gauge(sb, "stratum_ram_used_bytes", null, usedBytes);
+        gauge(sb, "stratum_ram_max_bytes",  null, maxBytes);
+
+        return sb.toString();
+    }
+
+    private static void gauge(StringBuilder sb, String name, String labels, double value) {
+        sb.append("# TYPE ").append(name).append(" gauge\n");
+        sb.append(name);
+        if (labels != null) sb.append('{').append(labels).append('}');
+        sb.append(' ').append(value).append('\n');
+    }
+}

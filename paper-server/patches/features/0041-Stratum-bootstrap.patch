Date: Sat, 30 May 2026 00:00:00 +0000
Subject: [PATCH] Stratum-bootstrap


diff --git a/mc/stratum/StratumPluginInstaller.java b/mc/stratum/StratumPluginInstaller.java
new file mode 100644
index 0000000000000000000000000000000000000000..d950e26b9ca266e38b823be33f2288710e1ddbe3
--- /dev/null
+++ b/mc/stratum/StratumPluginInstaller.java
@@ -0,0 +1,58 @@
+package mc.stratum;
+
+import org.apache.logging.log4j.LogManager;
+import org.apache.logging.log4j.Logger;
+
+import java.io.File;
+import java.io.InputStream;
+import java.net.URI;
+import java.net.http.HttpClient;
+import java.net.http.HttpRequest;
+import java.net.http.HttpResponse;
+import java.nio.file.Files;
+import java.nio.file.Path;
+import java.nio.file.StandardCopyOption;
+import java.time.Duration;
+
+/**
+ * Downloads and updates the StratumBootstrap plugin from stratumserver.net on every startup.
+ */
+public final class StratumPluginInstaller {
+
+    private static final Logger LOGGER = LogManager.getLogger("StratumPluginInstaller");
+    private static final String DOWNLOAD_URL = "https://stratumserver.net/downloads/StratumBootstrap.jar";
+    private static final String PLUGIN_FILENAME = "StratumBootstrap.jar";
+
+    private StratumPluginInstaller() {}
+
+    public static void installOrUpdate() {
+        final File pluginsDir = new File("plugins");
+        pluginsDir.mkdirs();
+
+        final Path dest = pluginsDir.toPath().resolve(PLUGIN_FILENAME);
+
+        try {
+            final HttpClient client = HttpClient.newBuilder()
+                .connectTimeout(Duration.ofSeconds(10))
+                .followRedirects(HttpClient.Redirect.NORMAL)
+                .build();
+
+            final HttpRequest request = HttpRequest.newBuilder()
+                .uri(URI.create(DOWNLOAD_URL))
+                .timeout(Duration.ofSeconds(30))
+                .GET()
+                .build();
+
+            final HttpResponse<InputStream> response = client.send(request, HttpResponse.BodyHandlers.ofInputStream());
+
+            if (response.statusCode() == 200) {
+                Files.copy(response.body(), dest, StandardCopyOption.REPLACE_EXISTING);
+                LOGGER.info("[Stratum] StratumBootstrap plugin installed/updated from {}", DOWNLOAD_URL);
+            } else {
+                LOGGER.warn("[Stratum] Failed to download StratumBootstrap (HTTP {}), skipping update.", response.statusCode());
+            }
+        } catch (Exception ex) {
+            LOGGER.warn("[Stratum] Could not reach {} to update plugin: {}", DOWNLOAD_URL, ex.getMessage());
+        }
+    }
+}
diff --git a/mc/stratum/StratumServer.java b/mc/stratum/StratumServer.java
new file mode 100644
index 0000000000000000000000000000000000000000..e54c8d9ad2585cc08fc1499cd9822b339c6577a3
--- /dev/null
+++ b/mc/stratum/StratumServer.java
@@ -0,0 +1,240 @@
+package mc.stratum;
+
+import mc.stratum.addons.AddonLoader;
+import mc.stratum.audit.AuditLog;
+import mc.stratum.commands.StratumCommand;
+import mc.stratum.console.StratumStatusLine;
+import io.papermc.paper.ServerBuildInfo;
+import mc.stratum.metrics.StratumMetricsServer;
+import mc.stratum.tweaks.TweakLoader;
+import mc.stratum.update.UpdateManager;
+import mc.stratum.update.VersionNotifier;
+import net.minecraft.server.MinecraftServer;
+import org.apache.logging.log4j.LogManager;
+import org.apache.logging.log4j.Logger;
+import org.bukkit.Bukkit;
+import org.bukkit.command.PluginCommand;
+import org.jline.terminal.Terminal;
+
+import java.io.File;
+import java.io.IOException;
+import java.io.InputStream;
+import java.security.KeyFactory;
+import java.security.PublicKey;
+import java.security.spec.X509EncodedKeySpec;
+import java.util.Base64;
+
+/**
+ * Central bootstrap singleton for Stratum MC.
+ *
+ * <p>Called early in {@code DedicatedServer.initServer()} via the sources patch.
+ */
+public final class StratumServer {
+
+    private static final Logger LOGGER = LogManager.getLogger("StratumServer");
+    private static StratumServer instance;
+
+    private TweakLoader       tweakLoader;
+    private AddonLoader       addonLoader;
+    private UpdateManager     updateManager;
+    private StratumMetricsServer metricsServer;
+    private StratumStatusLine statusLine;
+    private boolean           commandsRegistered = false;
+
+    private StratumServer() {}
+
+    /** Returns the singleton, creating it if necessary. */
+    public static StratumServer getInstance() {
+        if (instance == null) instance = new StratumServer();
+        return instance;
+    }
+
+    // ── Bootstrap ──────────────────────────────────────────────────────────────
+
+    /**
+     * Bootstraps all Stratum subsystems. Called from the patched
+     * {@code DedicatedServer.initServer()} method.
+     *
+     * @param minecraftServer the NMS server instance (not used directly after boot,
+     *                        but kept for future access via the singleton)
+     */
+    public void init(final MinecraftServer minecraftServer) {
+
+        // ── 1. Audit log ───────────────────────────────────────────────────────
+        AuditLog.getInstance().init(new File("logs/stratum-audit.log"));
+
+        // ── 2. Config ──────────────────────────────────────────────────────────
+        StratumConfig.get().load(new File("stratum.yml"));
+        LOGGER.info("[Stratum] Configuration loaded from stratum.yml");
+
+        // ── 3. Startup log ─────────────────────────────────────────────────────
+        final ServerBuildInfo build = ServerBuildInfo.buildInfo();
+        LOGGER.info("[Stratum] Stratum MC v{} build #{} starting.", build.minecraftVersionId(),
+                build.buildNumber().isPresent() ? build.buildNumber().getAsInt() : "DEV");
+
+        // ── 4. Ed25519 public key ─────────────────────────────────────────────
+        PublicKey primaryKey = null;
+        PublicKey tier2Key   = null;
+        try {
+            primaryKey = loadPublicKey("/stratum_public_key.pem");
+            LOGGER.info("[Stratum] Primary Ed25519 verification key loaded.");
+            // Tier-2 key is optional; if absent, tier-2 addons will fail verification
+            try {
+                tier2Key = loadPublicKey("/stratum_tier2_public_key.pem");
+                LOGGER.info("[Stratum] Tier-2 Ed25519 verification key loaded.");
+            } catch (Exception ignored) {
+                LOGGER.info("[Stratum] No tier-2 key found; tier-2 addons will not load.");
+            }
+        } catch (Exception ex) {
+            LOGGER.error("[Stratum] CRITICAL: Could not load primary verification key — "
+                    + "tweaks and addons will NOT be loaded: " + ex.getMessage());
+        }
+
+        // ── 5. Tweaks ──────────────────────────────────────────────────────────
+        tweakLoader = new TweakLoader();
+        int tweakCount = 0;
+        if (primaryKey != null) {
+            tweakLoader.loadAll(new File("tweaks"), primaryKey);
+            tweakCount = tweakLoader.getLoadedTweaks().size();
+        }
+
+        // ── 6. Addons ──────────────────────────────────────────────────────────
+        addonLoader = new AddonLoader();
+        int addonCount = 0;
+        if (primaryKey != null) {
+            addonLoader.loadAll(new File("addons"), primaryKey,
+                    tier2Key != null ? tier2Key : primaryKey);
+            addonCount = addonLoader.getInstalledAddons().size();
+        }
+
+        // ── 7. Startup summary ─────────────────────────────────────────────────
+        if (primaryKey != null) {
+            LOGGER.info("[Stratum] {} tweaks + {} addons loaded, all signature-verified ✓",
+                    tweakCount, addonCount);
+        } else {
+            LOGGER.warn("[Stratum] Signature verification unavailable — 0 tweaks, 0 addons loaded.");
+        }
+
+        // ── 8. UpdateManager ──────────────────────────────────────────────────
+        updateManager = new UpdateManager();
+
+        // ── 9. Status line ────────────────────────────────────────────────────
+        if (StratumConfig.statusLineEnabled) {
+            try {
+                // Obtain JLine terminal from Paper's console setup
+                final Terminal terminal = getJLineTerminal();
+                if (terminal != null) {
+                    statusLine = new StratumStatusLine(terminal);
+                    statusLine.start();
+                } else {
+                    LOGGER.info("[Stratum] JLine terminal not available; status line disabled.");
+                }
+            } catch (Exception ex) {
+                LOGGER.warn("[Stratum] Could not start status line: " + ex.getMessage());
+            }
+        }
+
+        // ── 10. Metrics server ────────────────────────────────────────────────
+        if (StratumConfig.metricsEnabled) {
+            metricsServer = new StratumMetricsServer(StratumConfig.metricsPort);
+            metricsServer.start();
+        }
+
+        // ── 11. Commands (/ST) registered after server is online ──────────────
+        // The command registration is deferred to after Bukkit initialises plugins.
+        // It is triggered from CraftServer.enablePlugins() → StratumServer.registerCommands()
+        // For now we store the managers so registerCommands() can use them.
+
+        AuditLog.getInstance().log("STRATUM_INIT_COMPLETE tweaks=" + tweakCount + " addons=" + addonCount);
+    }
+
+    /**
+     * Registers Stratum commands with the Bukkit command map.
+     * Called after Bukkit/CraftServer is fully initialised.
+     */
+    public void registerCommands() {
+        if (commandsRegistered) return;
+        commandsRegistered = true;
+        if (tweakLoader == null) tweakLoader = new TweakLoader();
+        if (addonLoader == null) addonLoader = new AddonLoader();
+        if (updateManager == null) updateManager = new UpdateManager();
+
+        final StratumCommand executor = new StratumCommand(tweakLoader, addonLoader, updateManager);
+
+        // Register via the server's command map
+        final org.bukkit.command.CommandMap commandMap = Bukkit.getServer().getCommandMap();
+        final org.bukkit.command.Command stCmd =
+                new mc.stratum.commands.STBukkitCommand("ST", executor);
+        commandMap.register("stratum", stCmd);
+
+        // Register VersionNotifier listener
+        final VersionNotifier notifier = new VersionNotifier(StratumConfig.tweaksApiUrl, updateManager);
+        // We need a plugin instance; use the first available plugin or a dummy plugin
+        registerListenerSafe(notifier);
+
+        LOGGER.info("[Stratum] /ST command registered.");
+    }
+
+    /** Called on server shutdown to clean up resources. */
+    public void shutdown() {
+        if (statusLine != null) statusLine.stop();
+        if (metricsServer != null) metricsServer.stop();
+        AuditLog.getInstance().close();
+    }
+
+    // ── Accessors ──────────────────────────────────────────────────────────────
+
+    public TweakLoader   getTweakLoader()   { return tweakLoader; }
+    public AddonLoader   getAddonLoader()   { return addonLoader; }
+    public UpdateManager getUpdateManager() { return updateManager; }
+
+    // ── Private helpers ────────────────────────────────────────────────────────
+
+    /**
+     * Loads an Ed25519 public key from a PEM resource bundled in the JAR.
+     *
+     * @param resourcePath classpath resource path, e.g. {@code "/stratum_public_key.pem"}
+     * @return the parsed {@link PublicKey}
+     * @throws Exception if the key cannot be read or parsed
+     */
+    private static PublicKey loadPublicKey(final String resourcePath) throws Exception {
+        try (InputStream in = StratumServer.class.getResourceAsStream(resourcePath)) {
+            if (in == null) throw new IOException("Resource not found: " + resourcePath);
+            final String pem = new String(in.readAllBytes())
+                    .replace("-----BEGIN PUBLIC KEY-----", "")
+                    .replace("-----END PUBLIC KEY-----", "")
+                    .replaceAll("\\s", "");
+            final byte[] keyBytes = Base64.getDecoder().decode(pem);
+            final KeyFactory kf = KeyFactory.getInstance("Ed25519");
+            return kf.generatePublic(new X509EncodedKeySpec(keyBytes));
+        }
+    }
+
+    /**
+     * Retrieves the JLine {@link Terminal} from Paper's terminal console appender,
+     * if available.
+     */
+    private static Terminal getJLineTerminal() {
+        try {
+            final Class<?> appenderClass = Class.forName(
+                    "net.minecrell.terminalconsole.TerminalConsoleAppender");
+            final java.lang.reflect.Field terminalField = appenderClass.getDeclaredField("terminal");
+            terminalField.setAccessible(true);
+            return (Terminal) terminalField.get(null);
+        } catch (Exception ex) {
+            return null;
+        }
+    }
+
+    private static void registerListenerSafe(final org.bukkit.event.Listener listener) {
+        try {
+            final org.bukkit.plugin.Plugin[] plugins = Bukkit.getPluginManager().getPlugins();
+            if (plugins.length > 0) {
+                Bukkit.getPluginManager().registerEvents(listener, plugins[0]);
+            }
+        } catch (Exception ex) {
+            LOGGER.warn("[Stratum] Could not register listener {}: {}",
+                    listener.getClass().getSimpleName(), ex.getMessage());
+        }
+    }
+}

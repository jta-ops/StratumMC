From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Stratum MC <dev@stratum.mc>
Date: Fri, 30 May 2026 00:00:00 +0000
Subject: [PATCH] Stratum audit log

Tamper-evident append-only log of every tweak/addon load, update, and
JAR swap event written to logs/stratum-audit.log.

diff --git a/mc/stratum/audit/AuditLog.java b/mc/stratum/audit/AuditLog.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffffffffffffffffffffffffffffffffffffffff
--- /dev/null
+++ b/mc/stratum/audit/AuditLog.java
@@ -0,0 +1,66 @@
+package mc.stratum.audit;
+
+import java.io.File;
+import java.io.FileWriter;
+import java.io.IOException;
+import java.io.PrintWriter;
+import java.time.Instant;
+import java.util.concurrent.locks.ReentrantLock;
+import java.util.logging.Logger;
+
+/**
+ * Singleton append-only audit log written to logs/stratum-audit.log.
+ * All writes are thread-safe.
+ */
+public final class AuditLog {
+
+    private static AuditLog INSTANCE;
+    private static final Logger LOG = Logger.getLogger("Stratum/Audit");
+
+    private final ReentrantLock lock = new ReentrantLock();
+    private PrintWriter writer;
+
+    private AuditLog() {}
+
+    public static AuditLog getInstance() {
+        if (INSTANCE == null) INSTANCE = new AuditLog();
+        return INSTANCE;
+    }
+
+    public void open(File logsDir) {
+        lock.lock();
+        try {
+            File auditFile = new File(logsDir, "stratum-audit.log");
+            logsDir.mkdirs();
+            writer = new PrintWriter(new FileWriter(auditFile, true));
+            log("AUDIT_LOG_OPENED");
+        } catch (IOException e) {
+            LOG.severe("Failed to open audit log: " + e.getMessage());
+        } finally {
+            lock.unlock();
+        }
+    }
+
+    public void log(String event) {
+        lock.lock();
+        try {
+            String line = Instant.now() + " [AUDIT] " + event;
+            if (writer != null) {
+                writer.println(line);
+                writer.flush();
+            }
+            LOG.fine(line);
+        } finally {
+            lock.unlock();
+        }
+    }
+
+    public void close() {
+        lock.lock();
+        try {
+            if (writer != null) { log("AUDIT_LOG_CLOSED"); writer.close(); }
+        } finally {
+            lock.unlock();
+        }
+    }
+}

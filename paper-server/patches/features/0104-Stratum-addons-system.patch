From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Stratum MC <dev@stratum.mc>
Date: Fri, 30 May 2026 00:00:00 +0000
Subject: [PATCH] Stratum addons system

Signed, opt-in, owner-toggleable feature modules. Same signature
verification model as tweaks but individually enable/disableable at
runtime.

diff --git a/mc/stratum/addons/AddonMeta.java b/mc/stratum/addons/AddonMeta.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffffffffffffffffffffffffffffffffffffffff
--- /dev/null
+++ b/mc/stratum/addons/AddonMeta.java
@@ -0,0 +1,16 @@
+package mc.stratum.addons;
+
+import java.util.List;
+
+/** Metadata read from META-INF/addon.json inside an addon JAR. */
+public record AddonMeta(
+        String id,
+        String name,
+        String description,
+        String version,
+        String author,
+        String minStratumVersion,
+        String maxStratumVersion,   // nullable — null means no upper bound
+        List<String> conflicts,     // IDs of incompatible addons
+        boolean requiresTier2Key
+) {}
diff --git a/mc/stratum/addons/StratumAddon.java b/mc/stratum/addons/StratumAddon.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffffffffffffffffffffffffffffffffffffffff
--- /dev/null
+++ b/mc/stratum/addons/StratumAddon.java
@@ -0,0 +1,11 @@
+package mc.stratum.addons;
+
+/**
+ * Optional interface that addon JARs may implement to receive lifecycle events.
+ * Addons that don't implement this are still loaded but cannot be toggled at runtime.
+ */
+public interface StratumAddon {
+    void onEnable();
+    void onDisable();
+    AddonMeta getMeta();
+}
diff --git a/mc/stratum/addons/AddonLoader.java b/mc/stratum/addons/AddonLoader.java
new file mode 100644
index 0000000000000000000000000000000000000000..ffffffffffffffffffffffffffffffffffffffff
--- /dev/null
+++ b/mc/stratum/addons/AddonLoader.java
@@ -0,0 +1,173 @@
+package mc.stratum.addons;
+
+import com.google.gson.Gson;
+import mc.stratum.audit.AuditLog;
+import mc.stratum.tweaks.TweakSignatureVerifier;
+import org.bukkit.command.CommandSender;
+
+import java.io.File;
+import java.io.InputStream;
+import java.io.InputStreamReader;
+import java.net.URL;
+import java.net.URLClassLoader;
+import java.security.PublicKey;
+import java.util.*;
+import java.util.logging.Logger;
+
+public final class AddonLoader {
+
+    private static AddonLoader INSTANCE;
+    private static final Logger LOG = Logger.getLogger("Stratum/Addons");
+    private static final Gson GSON = new Gson();
+
+    private final Map<String, AddonMeta>    installed = new LinkedHashMap<>();
+    private final Map<String, StratumAddon> instances = new LinkedHashMap<>();
+    private final Set<String>               enabled   = new LinkedHashSet<>();
+
+    private AddonLoader() {}
+
+    public static AddonLoader getInstance() {
+        if (INSTANCE == null) INSTANCE = new AddonLoader();
+        return INSTANCE;
+    }
+
+    public void loadAll(File addonsDir, PublicKey primaryKey, PublicKey tier2Key) {
+        if (!addonsDir.exists()) addonsDir.mkdirs();
+        File[] jars = addonsDir.listFiles((d, n) -> n.endsWith(".jar"));
+        if (jars == null || jars.length == 0) return;
+
+        for (File jar : jars) {
+            File sigFile = new File(jar.getParentFile(), jar.getName().replace(".jar", ".sig"));
+            if (!sigFile.exists()) {
+                LOG.warning("Skipping addon " + jar.getName() + ": no signature");
+                AuditLog.getInstance().log("ADDON_REJECTED jar=" + jar.getName() + " reason=missing_sig");
+                continue;
+            }
+            if (!TweakSignatureVerifier.verify(jar, sigFile, primaryKey)) {
+                LOG.severe("Skipping addon " + jar.getName() + ": signature invalid");
+                AuditLog.getInstance().log("ADDON_REJECTED jar=" + jar.getName() + " reason=bad_sig");
+                continue;
+            }
+            try {
+                URLClassLoader cl = new URLClassLoader(new URL[]{jar.toURI().toURL()},
+                        AddonLoader.class.getClassLoader());
+                AddonMeta meta = readMeta(cl);
+                if (meta == null) {
+                    LOG.warning("Addon " + jar.getName() + " missing META-INF/addon.json, skipping");
+                    continue;
+                }
+
+                // Tier-2 key check for sensitive addons
+                if (meta.requiresTier2Key() && tier2Key != null) {
+                    File sig2 = new File(jar.getParentFile(), jar.getName().replace(".jar", ".tier2.sig"));
+                    if (!sig2.exists() || !TweakSignatureVerifier.verify(jar, sig2, tier2Key)) {
+                        LOG.severe("Addon " + meta.id() + " requires tier-2 key — rejected");
+                        AuditLog.getInstance().log("ADDON_REJECTED id=" + meta.id() + " reason=tier2_fail");
+                        continue;
+                    }
+                }
+
+                // Conflict check
+                for (String conflict : meta.conflicts()) {
+                    if (installed.containsKey(conflict)) {
+                        LOG.warning("Addon " + meta.id() + " conflicts with " + conflict + " — skipping");
+                        continue;
+                    }
+                }
+
+                installed.put(meta.id(), meta);
+
+                // Try to find StratumAddon implementation
+                try {
+                    String mainClass = cl.getClass().getResourceAsStream("META-INF/addon.json") != null
+                            ? meta.id() : null;
+                    // Load instance if the JAR provides a main class property
+                    InputStream is = cl.getResourceAsStream("META-INF/addon.json");
+                    if (is != null) {
+                        Map<?,?> map = GSON.fromJson(new InputStreamReader(is), Map.class);
+                        Object mc = map.get("mainClass");
+                        if (mc instanceof String) {
+                            Class<?> cls = cl.loadClass((String) mc);
+                            if (StratumAddon.class.isAssignableFrom(cls)) {
+                                StratumAddon instance = (StratumAddon) cls.getDeclaredConstructor().newInstance();
+                                instances.put(meta.id(), instance);
+                            }
+                        }
+                    }
+                } catch (Exception ignored) {}
+
+                LOG.info("Loaded addon: " + meta.name() + " v" + meta.version());
+                AuditLog.getInstance().log("ADDON_LOADED id=" + meta.id() + " version=" + meta.version());
+            } catch (Exception e) {
+                LOG.severe("Failed to load addon " + jar.getName() + ": " + e.getMessage());
+            }
+        }
+    }
+
+    public void enableAddon(String id, CommandSender feedback) {
+        AddonMeta meta = installed.get(id);
+        if (meta == null) { feedback.sendMessage("§cAddon not found: " + id); return; }
+        if (enabled.contains(id)) { feedback.sendMessage("§eAlready enabled: " + id); return; }
+        StratumAddon instance = instances.get(id);
+        if (instance != null) {
+            try { instance.onEnable(); } catch (Exception e) {
+                feedback.sendMessage("§cError enabling " + id + ": " + e.getMessage()); return;
+            }
+        }
+        enabled.add(id);
+        feedback.sendMessage("§a[Stratum] Enabled addon: " + meta.name());
+        AuditLog.getInstance().log("ADDON_ENABLED id=" + id);
+    }
+
+    public void disableAddon(String id, CommandSender feedback) {
+        if (!installed.containsKey(id)) { feedback.sendMessage("§cAddon not found: " + id); return; }
+        if (!enabled.contains(id)) { feedback.sendMessage("§eNot enabled: " + id); return; }
+        StratumAddon instance = instances.get(id);
+        if (instance != null) {
+            try { instance.onDisable(); } catch (Exception e) {
+                feedback.sendMessage("§cError disabling " + id + ": " + e.getMessage()); return;
+            }
+        }
+        enabled.remove(id);
+        feedback.sendMessage("§a[Stratum] Disabled addon: " + installed.get(id).name());
+        AuditLog.getInstance().log("ADDON_DISABLED id=" + id);
+    }
+
+    public void printInfo(String id, CommandSender sender) {
+        AddonMeta m = installed.get(id);
+        if (m == null) { sender.sendMessage("§cAddon not found: " + id); return; }
+        sender.sendMessage("§6[Stratum] §f" + m.name() + " v" + m.version());
+        sender.sendMessage("§7  Author : §f" + m.author());
+        sender.sendMessage("§7  Desc   : §f" + m.description());
+        sender.sendMessage("§7  Compat : §fStratum >= " + m.minStratumVersion() +
+                (m.maxStratumVersion() != null ? ", <= " + m.maxStratumVersion() : ""));
+        sender.sendMessage("§7  Status : " + (enabled.contains(id) ? "§aEnabled" : "§cDisabled"));
+        if (!m.conflicts().isEmpty())
+            sender.sendMessage("§7  Conflicts: §c" + String.join(", ", m.conflicts()));
+    }
+
+    private AddonMeta readMeta(URLClassLoader cl) {
+        try (InputStream is = cl.getResourceAsStream("META-INF/addon.json")) {
+            if (is == null) return null;
+            Map<?,?> map = GSON.fromJson(new InputStreamReader(is), Map.class);
+            List<String> conflicts = new ArrayList<>();
+            Object c = map.get("conflicts");
+            if (c instanceof List<?>) for (Object o : (List<?>) c) conflicts.add(o.toString());
+            return new AddonMeta(
+                    str(map,"id"), str(map,"name"), str(map,"description"),
+                    str(map,"version"), str(map,"author"),
+                    str(map,"minStratumVersion"), (String) map.get("maxStratumVersion"),
+                    conflicts, Boolean.TRUE.equals(map.get("requiresTier2Key")));
+        } catch (Exception e) { return null; }
+    }
+
+    private static String str(Map<?,?> m, String k) {
+        Object v = m.get(k); return v != null ? v.toString() : "";
+    }
+
+    public List<String> getInstalledAddonIds()  { return new ArrayList<>(installed.keySet()); }
+    public List<String> getEnabledAddonIds()    { return new ArrayList<>(enabled); }
+    public boolean isEnabled(String id)         { return enabled.contains(id); }
+    public int installedCount()                 { return installed.size(); }
+    public int enabledCount()                   { return enabled.size(); }
+}
